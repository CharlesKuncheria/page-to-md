{
  "manifest_version": 3,
  "name": "Page to Markdown",
  "version": "2.0.0",
  "description": "Click the icon to copy the current page as Markdown",
  "permissions": ["activeTab", "scripting", "clipboardWrite", "downloads"],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Copy page as Markdown"
  }
}
